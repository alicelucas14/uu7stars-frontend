---
// ===== src/pages/promotions/[slug].astro =====
// --- UPDATED for Server-Side Rendering (SSR) ---

import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Base from '../../layouts/Base.astro';
import { getPromotions, getReviews } from '../../services/api';
import MobileAppShell from '../../components/MobileAppShell.astro';
import { useTranslations } from '../../lib/i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'en';
const t = useTranslations(locale);

// --- REMOVED getStaticPaths ---
// This function is removed to make the page dynamic (SSR).
// The build warning will now be gone.

const { slug } = Astro.params;

// This code now runs on the server for every request to this page.
const promo = (await getPromotions(locale)).find(p => p.slug === slug);

if (!promo) {
    return new Response(null, { status: 404, statusText: 'Not Found' });
}

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
const img = (u: string) => u?.startsWith('http') ? u : `${API_BASE_URL}${u}`;

let reviews: any[] = [];
try { reviews = await getReviews(locale); } catch {}

const promoTitle = promo.title;
const promoSubtitle = promo.subtitle;
const promoDescription = promo.description;
const promoBadgeText = promo.badgeText;
const promoCtaText = promo.ctaText;
const promoDetails = promo.details;

const canonical = new URL(`/promotions/${promo.slug}/`, Astro.site).toString();
const title = `${promoTitle} — Starsuu7 Promotions (UU7 • 777)`;
const description = promoSubtitle || promoDescription || 'Explore Starsuu7 (UU7 • 777) promotions: bonuses, cashback and seasonal offers.';

const relatedReviews = reviews
  .filter(r => {
    const hay = `${r.title} ${r.excerpt} ${r.gameName}`.toLowerCase();
    const keys = [promoTitle, 'starsuu7', 'uu7', '777'];
    return keys.some(k => hay.includes(k.toLowerCase()));
  })
  .slice(0, 6);

const ldPromotion = {
  '@context': 'https://schema.org',
  '@type': 'Offer',
  name: promoTitle,
  description: promoDescription,
  url: canonical,
  image: img(promo.imageUrl),
  availability: 'https://schema.org/InStock',
  priceCurrency: 'INR',
  seller: { '@type': 'Organization', name: 'Starsuu7' }
};
---
<Base title={title} description={description} canonical={canonical} jsonLd={ldPromotion}>
  
  <div class="desktop-layout">
    <Header lang={locale} />
    <main>
      <section class="promo-hero">
        <div class="container">
          <a href="/promotions/" class="back">{t('promotionPost.backLink')}</a>
          <h1 class="title">{promoTitle}</h1>
          {promoBadgeText && (
            <span class="badge" style={`--badge:${promo.badgeColor || 'var(--brand-orange)'}`}>{promoBadgeText}</span>
          )}
          <p class="sub" set:html={t('promotionPost.subheading')}></p>
          <div class="hero-media">
            <img src={img(promo.imageUrl)} alt={promoTitle} width="1280" height="720" loading="eager" />
          </div>
          <div class="cta-row">
            {promo.ctaLink && (<a href={promo.ctaLink} class="btn">{promoCtaText || t('promotionPost.claimOffer')}</a>)}
            <a href="/#download" class="ghost">{t('promotionPost.downloadApp')}</a>
          </div>
        </div>
      </section>
      <section class="promo-body">
        <div class="container">
          <div class="content">
            {promoSubtitle && <p class="lead">{promoSubtitle}</p>}
            <p>{promoDescription}</p>
            {promoDetails && promoDetails.length > 0 && (
              <div class="details">
                <h2>{t('promotionPost.howToClaim')}</h2>
                <ol>
                  {promoDetails.map((line) => <li>{line}</li>)}
                </ol>
              </div>
            )}
            <aside class="note">
              <strong>{t('promotionPost.noteTitle')}</strong> {t('promotionPost.noteBody')}
            </aside>
          </div>
        </div>
      </section>
      {relatedReviews.length > 0 && (
        <section class="related">
          <div class="container">
            <header class="section-head">
              <h2>{t('promotionPost.relatedTitle')}</h2>
              <p class="muted">{t('promotionPost.relatedDescription')}</p>
            </header>
            <div class="cards">
              {relatedReviews.map((r) => (
                <a class="card" href={`/reviews/${r.slug}/`}>
                  <img class="thumb" src={img(r.image)} alt={r.title} width="420" height="260" loading="lazy" />
                  <div class="meta">
                    <span class="pill">★ {r.rating}/5</span>
                    <span class="game">{r.gameName}</span>
                  </div>
                  <h3 class="ctitle">{r.title}</h3>
                  <p class="excerpt">{r.excerpt}</p>
                </a>
              ))}
            </div>
            <div class="cluster-cta">
              <a class="more" href="/reviews/">{t('promotionPost.seeAllReviews')}</a>
            </div>
          </div>
        </section>
      )}
    </main>
    <Footer lang={locale} />
  </div>

  <div class="mobile-layout">
    <MobileAppShell title="Promotion" active="promos" showBack={true} lang={locale}>
      <main>
        <section class="promo-hero">
          <div class="container">
            <h1 class="title">{promoTitle}</h1>
            {promoBadgeText && (
              <span class="badge" style={`--badge:${promo.badgeColor || 'var(--brand-orange)'}`}>{promoBadgeText}</span>
            )}
            <p class="sub" set:html={t('promotionPost.subheadingMobile')}></p>
            <div class="hero-media">
              <img src={img(promo.imageUrl)} alt={promoTitle} width="1280" height="720" loading="eager" />
            </div>
            <div class="cta-row">
              {promo.ctaLink && (<a href={promo.ctaLink} class="btn">{promoCtaText || t('promotionPost.claimOffer')}</a>)}
              <a href="/#download" class="ghost">{t('promotionPost.downloadApp')}</a>
            </div>
          </div>
        </section>
        <section class="promo-body">
          <div class="container">
            <div class="content">
              {promoSubtitle && <p class="lead">{promoSubtitle}</p>}
              <p>{promoDescription}</p>
              {promoDetails && promoDetails.length > 0 && (
                <div class="details">
                  <h2>{t('promotionPost.howToClaim')}</h2>
                  <ol>
                    {promoDetails.map((line) => <li>{line}</li>)}
                  </ol>
                </div>
              )}
            </div>
          </div>
        </section>
      </main>
    </MobileAppShell>
    <Footer lang={locale} />
  </div>

  <style>
    /* Styles remain unchanged */
    .desktop-layout { display: none; } .mobile-layout { display: block; } @media (min-width: 768px) { .desktop-layout { display: block; } .mobile-layout { display: none; } } .container{max-width:1100px;margin-inline:auto;padding-inline:16px;} .promo-hero{padding-block:32px;background:var(--surface);border-bottom:1px solid var(--ring);} .back{display:inline-block;margin-bottom:10px;text-decoration:none;color:var(--text-secondary);} .back:hover{color:var(--text-primary);} .title{margin:0 0 6px;font-size:clamp(26px,4vw,38px);color:var(--text-primary);} .badge{display:inline-block;margin-top:6px;font-size:12px;font-weight:900;padding:6px 10px;border-radius:999px;background:var(--brand-orange);color:var(--ink);border:1px solid color-mix(in oklab,#000 12%, var(--brand-orange));} .badge{background:var(--badge,var(--brand-orange));} .sub{color:var(--text-secondary);margin:8px 0 16px;} .hero-media img{width:100%;height:auto;border-radius:16px;border:1px solid var(--ring);box-shadow:var(--shadow-md);} .cta-row{display:flex;gap:12px;margin-top:14px;flex-wrap:wrap;} .btn{display:inline-flex;align-items:center;justify-content:center;padding:12px 16px;border-radius:12px;background:linear-gradient(180deg,var(--brand-gold),var(--brand-orange));color:var(--ink);font-weight:900;text-decoration:none;border:1px solid color-mix(in oklab,#000 12%,var(--brand-gold));} .ghost{display:inline-flex;align-items:center;justify-content:center;padding:12px 16px;border-radius:12px;background:var(--surface-2);border:1px dashed var(--ring);color:var(--text-secondary);text-decoration:none;font-weight:800;} .ghost:hover{border-style:solid;color:var(--text-primary);} .promo-body{padding-block:28px;background:var(--surface);} .content{display:grid;gap:14px;} .lead{font-weight:600;color:var(--text-primary);} .details h2{margin:12px 0 6px;font-size:18px;} .details ol{padding-left:18px;} .note{margin-top:8px;padding:10px 12px;border:1px dashed var(--ring);border-radius:12px;background:var(--surface-2);color:var(--text-secondary);} .related{padding-block:36px;background:var(--surface-2);border-top:1px solid var(--ring);} .section-head{text-align:center;max-width:720px;margin:0 auto 18px;} .section-head h2{margin:0 0 6px;font-size:clamp(20px,3.6vw,28px);} .muted{color:var(--text-secondary);} .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;} .card{text-decoration:none;background:var(--surface);border:1px solid var(--ring);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;} .thumb{width:100%;aspect-ratio:16/9;object-fit:cover;} .meta{display:flex;gap:8px;align-items:center;padding:10px 12px 0;} .pill{background:var(--brand-orange);color:var(--ink);font-weight:900;border-radius:999px;padding:4px 8px;border:1px solid color-mix(in oklab,#000 12%, var(--brand-orange));font-size:12px;} .game{font-size:12px;color:var(--text-secondary);} .ctitle{margin:8px 12px 6px;color:var(--text-primary);font-size:16px;} .excerpt{margin:0 12px 14px;color:var(--text-secondary);font-size:14px;} .cluster-cta{display:flex;justify-content:center;margin-top:10px;} .more{font-weight:700;color:var(--brand-orange);text-decoration:none;} .more:hover{text-decoration:underline;} @media (max-width: 767px) { .promo-hero { padding-block: 24px; border-bottom: none; } .back { display: none; } .promo-body { padding-block: 0 24px; } .related { display: none; } }
  </style>
</Base>