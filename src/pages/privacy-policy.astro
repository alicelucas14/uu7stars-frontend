---
// ===== src/pages/privacy-policy.astro =====
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileAppShell from '../components/MobileAppShell.astro';
import { useTranslations } from '../lib/i18n';
import type { Locale } from '../i18n';

const locale: Locale = 'en';
const t = useTranslations(locale);

const pageTitle = t('privacyPolicyPage.title');
const pageDescription = t('privacyPolicyPage.description');
const h1 = t('privacyPolicyPage.h1');
const lastUpdated = t('privacyPolicyPage.lastUpdated');
const sections: {title: string, content: string}[] = t('privacyPolicyPage.sections');
const canonical = new URL('/privacy-policy/', Astro.site).toString();
---

<Base title={pageTitle} description={pageDescription} canonical={canonical}>

  <div class="desktop-layout">
    <Header lang={locale} />
    <main class="legal-page">
      <div class="container">
        <div class="content-box">
          <h1>{h1}</h1>
          <p class="last-updated">{lastUpdated}</p>
          
          {sections.map(section => (
            <section>
              <h2>{section.title}</h2>
              <div set:html={section.content} />
            </section>
          ))}
        </div>
      </div>
    </main>
    <Footer lang={locale} />
  </div>

  <div class="mobile-layout">
    <MobileAppShell title={h1} showBack={true} lang={locale}>
      <main class="legal-page">
        <div class="container">
          <div class="content-box">
            <h1>{h1}</h1>
            <p class="last-updated">{lastUpdated}</p>
            
            {/* Render all sections, as mobile content is now also in the JSON */}
            {sections.map(section => (
               <section>
                <h2>{section.title}</h2>
                <div set:html={section.content} />
              </section>
            ))}
          </div>
        </div>
      </main>
    </MobileAppShell>
    <Footer lang={locale} />
  </div>
</Base>

<style>
  /* Use :global to style content from set:html */
  .legal-page :global(p), 
  .legal-page :global(ul), 
  .legal-page :global(ol) {
    color: var(--text-secondary);
    font-size: 16px;
    line-height: 1.8;
    margin-bottom: 1em;
  }
  .legal-page :global(ul), .legal-page :global(ol) { padding-left: 24px; }
  .legal-page :global(li) { margin-bottom: 8px; }
  .legal-page :global(strong) { color: var(--text-primary); }

  /* Other styles remain unchanged */
  .desktop-layout { display: none; } .mobile-layout { display: block; } @media (min-width: 768px) { .desktop-layout { display: block; } .mobile-layout { display: none; } } .legal-page { padding-block: 48px; } @media (max-width: 767px) { .legal-page { padding-block: 24px; } .mobile-layout .content-box { border-radius: 0; border-inline: none; padding-inline: 16px; } .mobile-layout .container { padding-inline: 0; } } .content-box { background-color: var(--surface); border: 1px solid var(--ring); border-radius: 24px; padding: clamp(24px, 5vw, 48px); max-width: 900px; margin-inline: auto; } h1 { font-size: clamp(28px, 4vw, 40px); margin-bottom: 8px; text-align: center; color: var(--text-primary); } .last-updated { text-align: center; color: var(--text-secondary); font-size: 14px; margin-bottom: 32px; } section { margin-bottom: 32px; } h2 { font-size: clamp(20px, 3vw, 24px); margin-top: 48px; margin-bottom: 16px; border-bottom: 1px solid var(--ring); padding-bottom: 8px; color: var(--text-primary); } h2:first-of-type { margin-top: 0; }
</style>