---
// ===== src/pages/hi/reviews/[slug].astro =====
// --- UPDATED: Now includes the CommentsSection component ---
import { marked } from 'marked';
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import MobileAppShell from '../../../components/MobileAppShell.astro';
import RecentPosts from '../../../components/RecentPosts.astro';
import SidebarPromos from '../../../components/SidebarPromos.astro';
import SidebarCta from '../../../components/SidebarCta.astro';
import CommentsSection from '../../../components/CommentsSection.astro'; // <-- IMPORT the component
import { getReviewBySlug } from '../../../services/api';
import { useTranslations } from '../../../lib/i18n';
import type { Locale } from '../../../i18n';

const locale: Locale = 'hi';
const t = useTranslations(locale);

const { slug } = Astro.params;
const review = await getReviewBySlug(slug as string, locale);

if (!review) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const ratingPercent = (review.rating / 5) * 100;
const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
const imageUrl = review.image.startsWith('http') ? review.image : `${API_BASE_URL}${review.image}`;
const contentHtml = await marked.parse(review.body.hi);

const pageTitle = t('reviewPost.title').replace('{reviewTitle}', review.title.hi);
const pageDescription = t('reviewPost.description').replace('{gameName}', review.gameName);
const canonical = new URL(`/hi/reviews/${slug}/`, Astro.site).toString();

const reviewJsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "Game",
    "name": review.gameName
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": review.rating,
    "bestRating": "5",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "Starsuu7"
  },
  "reviewBody": review.excerpt.hi || pageDescription,
  "publisher": {
    "@type": "Organization",
    "name": "Starsuu7"
  }
};
---
<Base title={pageTitle} description={pageDescription} canonical={canonical} jsonLd={reviewJsonLd}>

  <div class="desktop-layout">
    <Header lang={locale} />
    <main class="review-page">
      <div class="container">
        <div class="layout-grid">
          
          <article class="main-content">
            <header class="review-header">
              <h1>{review.title.hi}</h1>
              <p class="review-game-name" set:html={t('reviewPost.reviewOf').replace('{gameName}', review.gameName)}></p>
            </header>
            <div class="prose" set:html={contentHtml} />
            
            <!-- ADDED Comments Section for Desktop -->
            <CommentsSection reviewId={review._id} lang={locale} />

          </article>
          
          <aside class="sidebar">
            <div class="sidebar-inner">
              <div class="summary-card">
                <img src={imageUrl} alt={`Cover art for ${review.gameName}`} class="summary-image" />
                <div class="summary-content">
                  <div class="rating-box">
                    <div class="rating-score">{review.rating.toFixed(1)}</div>
                    <div class="rating-stars" aria-label={`Rating: ${review.rating} out of 5 stars`} style={`--rating-percent: ${ratingPercent}%`}></div>
                    <div class="rating-label">{t('reviewPost.ourRating')}</div>
                  </div>
                  <dl class="summary-meta">
                    <div><dt>{t('reviewPost.game')}</dt><dd>{review.gameName}</dd></div>
                    <div><dt>{t('reviewPost.developer')}</dt><dd>{review.developer}</dd></div>
                  </dl>
                  
                  {review.pros?.hi && review.pros.hi.length > 0 && (
                    <div class="pros-cons">
                      <h4>{t('reviewPost.pros')}</h4>
                      <ul>{review.pros.hi.map(pro => <li>{pro}</li>)}</ul>
                    </div>
                  )}
                   {review.cons?.hi && review.cons.hi.length > 0 && (
                    <div class="pros-cons">
                      <h4>{t('reviewPost.cons')}</h4>
                      <ul>{review.cons.hi.map(con => <li>{con}</li>)}</ul>
                    </div>
                  )}
                </div>
              </div>
              <RecentPosts lang={locale} />
              <SidebarPromos lang={locale} />
              <SidebarCta lang={locale} />
            </div>
          </aside>
        </div>
      </div>
    </main>
    <Footer lang={locale} />
  </div>

  <div class="mobile-layout">
    <MobileAppShell title="गेम समीक्षा" showBack={true} lang={locale}>
      <main class="review-page">
        <div class="container">
          <article class="main-content">
            <header class="review-header">
              <h1>{review.title.hi}</h1>
              <p class="review-game-name" set:html={t('reviewPost.reviewOf').replace('{gameName}', review.gameName)}></p>
            </header>
            <aside class="sidebar">
              <div class="summary-card">
                <img src={imageUrl} alt={`Cover art for ${review.gameName}`} class="summary-image" />
                <div class="summary-content">
                  <div class="rating-box">
                    <div class="rating-score">{review.rating.toFixed(1)}</div>
                    <div class="rating-stars" aria-label={`Rating: ${review.rating} out of 5 stars`} style={`--rating-percent: ${ratingPercent}%`}></div>
                    <div class="rating-label">{t('reviewPost.ourRating')}</div>
                  </div>
                  <dl class="summary-meta">
                    <div><dt>{t('reviewPost.game')}</dt><dd>{review.gameName}</dd></div>
                    <div><dt>{t('reviewPost.developer')}</dt><dd>{review.developer}</dd></div>
                  </dl>
                  {review.pros?.hi && review.pros.hi.length > 0 && (
                    <div class="pros-cons">
                      <h4>{t('reviewPost.pros')}</h4>
                      <ul>{review.pros.hi.map(pro => <li>{pro}</li>)}</ul>
                    </div>
                  )}
                  {review.cons?.hi && review.cons.hi.length > 0 && (
                    <div class="pros-cons">
                      <h4>{t('reviewPost.cons')}</h4>
                      <ul>{review.cons.hi.map(con => <li>{con}</li>)}</ul>
                    </div>
                  )}
                </div>
              </div>
            </aside>
            <div class="prose" set:html={contentHtml} />

            <!-- ADDED Comments Section for Mobile -->
            <CommentsSection reviewId={review._id} lang={locale} />

          </article>
        </div>
      </main>
    </MobileAppShell>
    <Footer lang={locale} />
  </div>
</Base>
<style>
  /* Styles are identical to English version */
  .desktop-layout { display: none; } .mobile-layout { display: block; } @media (min-width: 768px) { .desktop-layout { display: block; } .mobile-layout { display: none; } } .review-page { padding-block: 48px; } @media (max-width: 767px) { .review-page { padding-block: 24px; } } .layout-grid { display: grid; grid-template-columns: 1fr; gap: 32px; } @media (min-width: 900px) { .layout-grid { grid-template-columns: 2fr 1fr; } } @media (max-width: 899px) { .main-content { order: 2; } .sidebar { order: 1; } } .review-header { margin-bottom: 24px; } .review-header h1 { font-size: clamp(28px, 4vw, 40px); margin-bottom: 4px; } .review-game-name { color: var(--text-secondary); } .prose { font-size: 17px; line-height: 1.8; } @media (max-width: 899px) { .prose { margin-top: 32px; } } .prose > :global(* + *) { margin-top: 1.25em; } .prose :global(h2), .prose :global(h3) { margin-top: 2em; margin-bottom: 1em; } .sidebar-inner { position: sticky; top: 88px; display: grid; gap: 24px; } .summary-card { background: var(--surface); border: 1px solid var(--ring); border-radius: 18px; overflow: hidden; } .summary-image { width: 100%; aspect-ratio: 16/9; object-fit: cover; } .summary-content { padding: 20px; } .rating-box { text-align: center; background: var(--brand-orange); color: var(--ink); border-radius: 12px; padding: 12px; margin-bottom: 16px; } .rating-score { font-size: 2.5rem; font-weight: 800; line-height: 1; } .rating-stars { position: relative; display: inline-block; font-size: 1.5rem; letter-spacing: 2px; color: rgba(255, 255, 255, 0.3); margin-block: -4px 4px; } .rating-stars::before { content: '★★★★★'; } .rating-stars::after { content: '★★★★★'; position: absolute; top: 0; left: 0; color: white; width: var(--rating-percent, 0%); overflow: hidden; white-space: nowrap; } .rating-label { font-weight: 600; font-size: 0.9rem; } .summary-meta { font-size: 0.9rem; } .summary-meta > div { display: flex; justify-content: space-between; padding-block: 8px; border-bottom: 1px solid var(--ring); } .summary-meta > div:last-child { border-bottom: none; } .summary-meta dt { color: var(--text-secondary); } .summary-meta dd { font-weight: 600; color: var(--text-primary); } .pros-cons { margin-top: 16px; } .pros-cons h4 { font-weight: 700; margin-bottom: 8px; font-size: 1rem; } .pros-cons ul { list-style: none; padding: 0; font-size: 0.9rem; color: var(--text-secondary); } .pros-cons li { position: relative; padding-left: 20px; margin-bottom: 4px; } .pros-cons h4:first-of-type + ul li::before { content: '✓'; position: absolute; left: 0; color: var(--brand-green); font-weight: 700; } .pros-cons h4:not(:first-of-type) + ul li::before { content: '✕'; position: absolute; left: 0; color: #ef4444; }
</style>