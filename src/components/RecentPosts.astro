---
// ===== src/components/RecentPosts.astro =====

import { getBlogPosts } from '../services/api';
import type { BlogPostListItem } from '../services/api';
import type { Locale } from '../i18n';
import { createPath } from '../lib/paths';

interface Props {
  excludeSlug?: string;
  limit?: number;
  lang?: Locale;
}
const { excludeSlug, limit = 4, lang = 'en' } = Astro.props;

const posts = await getBlogPosts(lang);
const recent = posts.filter(p => p.slug !== excludeSlug).slice(0, limit);

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
const toAbsolute = (p?: string) => !p ? '' : (p.startsWith('http') ? p : new URL(p, API_BASE_URL).toString());
---
{recent.length > 0 && (
  <div class="sidebar-widget">
    <h3 class="widget-title">Recent Posts</h3>
    <div class="post-list">
      {recent.map((post: BlogPostListItem) => (
        <a href={createPath(`/blog/${post.slug}/`, lang)} class="post-item">
          <img src={toAbsolute(post.image)} alt={`Thumbnail for ${post.title}`} width="80" height="50" loading="lazy" />
          <div class="post-info">
            <span class="post-title">{post.title}</span>
            <time datetime={post.publishedAt} class="post-date">
              {new Date(post.publishedAt).toLocaleDateString(lang === 'hi' ? 'hi-IN' : 'en-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
            </time>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
<style>
.sidebar-widget {
  background: var(--surface);
  border: 1px solid var(--ring);
  border-radius: 16px;
  padding: 20px;
}
.widget-title {
  margin: 0 0 16px;
  font-size: 18px;
  border-bottom: 1px solid var(--ring);
  padding-bottom: 12px;
}
.post-list {
  display: grid;
  gap: 16px;
}
.post-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 12px;
  align-items: center;
  text-decoration: none;
}
.post-item img {
  width: 80px;
  height: 50px;
  object-fit: cover;
  border-radius: 8px;
}
.post-title {
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  font-size: 14px;
  margin-bottom: 4px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.post-item:hover .post-title {
  color: var(--brand-orange);
}
.post-date {
  font-size: 12px;
  color: var(--text-secondary);
}
</style>