---
// ===== src/components/Promotions.astro =====
// --- REFACTORED: Now uses the centralized 'useTranslations' utility ---

import type { Locale } from '../i18n';
import { useTranslations } from '../lib/i18n';

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props as Props;
const t = useTranslations(lang);

// --- UPDATED: Fetch all content dynamically from the locale file ---
const title = t('promotions.title');
const description = t('promotions.description');
const viewAllText = t('promotions.viewAll');

// Type-safe check for the steps array
const stepsResult = t('promotions.steps');
const promoSteps: { num: number; title: string; body: string }[] = Array.isArray(stepsResult) 
  ? stepsResult.map((step, index) => ({ ...step, num: index + 1 })) 
  : [];
---
<section class="promos-section-steps">
  <div class="container">
    <header class="section-head">
      {/* UPDATED: Use dynamic text */}
      <h2>{title}</h2>
      <p class="muted">{description}</p>
    </header>

    <div class="grid">
      {/* UPDATED: Map over dynamic steps */}
      {promoSteps.map(step => (
        <div class="step-card">
          <div class="number" aria-hidden="true">{step.num}</div>
          <h3 class="title">{step.title}</h3>
          <p class="body">{step.body}</p>
        </div>
      ))}
    </div>
    
    <div class="more-link-container">
      {/* UPDATED: Use dynamic button text */}
      <a href="/promotions/" class="btn-view-all">
        {viewAllText}
      </a>
    </div>
  </div>
</section>

<style>
  /* Styles remain unchanged */
  .promos-section-steps { 
    padding-block: 48px; 
    background-color: var(--surface);
    border-top: 1px solid var(--ring);
  }
  .section-head { 
    text-align: center; 
    max-width: 640px; 
    margin-inline: auto; 
    margin-bottom: 32px; 
  }
  .section-head h2 { 
    font-size: clamp(24px, 4vw, 36px); 
    margin-bottom: 8px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    position: relative;
  }

  .step-card {
    background: var(--surface-2);
    border: 1px solid var(--ring);
    border-radius: 18px;
    padding: 24px;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .number {
    display: inline-flex;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 99px;
    background: var(--brand-gold);
    color: var(--ink);
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 16px;
    border: 3px solid var(--surface);
    box-shadow: var(--shadow-md);
  }
  .title { 
    margin: 0 0 8px; 
    font-size: 18px;
    color: var(--text-primary);
  }
  .body { 
    margin: 0; 
    color: var(--text-secondary); 
    font-size: 15px;
  }

  .more-link-container {
    margin-top: 32px;
    text-align: center;
  }
  .btn-view-all {
    display: inline-flex;
    padding: 12px 24px;
    border-radius: 12px;
    background: var(--surface-2);
    border: 1px dashed var(--ring);
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s;
  }
  .btn-view-all:hover {
    border-style: solid;
    color: var(--brand-orange);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
</style>