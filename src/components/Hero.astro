---
// src/components/Hero.astro — REFACTORED for i18n
import type { Locale } from '../i18n';
import { useTranslations } from '../lib/i18n';

// --- ADDED: Language props and translation function ---
interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props as Props;
const t = useTranslations(lang);
// ---

// Use a single, high-quality hero image for LCP.
const HERO_WEBP = "/wordpress/STARSUU7-Game.webp";
---

<section class="hero" role="region" aria-label="Starsuu7 introduction">
  <div class="container hero__inner">
    <div class="hero__copy">
      {/* UPDATED: Use the 't' function for the headline */}
      <h1>{t('hero.h1')}</h1>

      {/* UPDATED: Use the 't' function with set:html for rich text */}
      <p class="lead" set:html={t('hero.lead')}></p>

      <div class="cta-group">
        {/* UPDATED: Use the 't' function for the aria-label */}
        <a href="#download" class="hero-cta-unit" aria-label={t('hero.ctaAriaLabel')}>
          <div class="btn-hero-top">
            <svg aria-hidden="true" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" x2="12" y1="15" y2="3"/>
            </svg>
            {/* UPDATED: Use the 't' function for the button text */}
            <span>{t('hero.ctaButton')}</span>
          </div>
          <div class="btn-hero-bonus">
            {/* UPDATED: Use the 't' function for the bonus text */}
            {t('hero.ctaBonus')}
          </div>
        </a>
      </div>
    </div>

    <div class="art-wrap">
      <picture class="hero-art-picture">
        <source srcset={`${HERO_WEBP} 1x`} type="image/webp" />
        <img
          class="hero__art"
          src={HERO_WEBP}
          alt={t('hero.imageAlt')}
          decoding="async"
          fetchpriority="high"
          loading="eager"
          width="1160" height="1000"
          sizes="(max-width: 980px) 90vw, 44vw"
        />
      </picture>
      <noscript>
        <img class="hero__art noscript" src={HERO_WEBP} width="1160" height="1000" alt={t('hero.imageAlt')} />
      </noscript>
    </div>
  </div>
</section>

<style>
  /* Styles remain unchanged */
  .hero {
    padding-block: 56px 80px;
    position: relative;
    overflow: clip;
    background: linear-gradient(170deg, var(--brand-orange), var(--brand-gold));
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .hero__inner {
    display: grid;
    gap: 48px;
    grid-template-columns: 1.1fr .9fr;
    align-items: center;
  }
  .hero__copy h1 {
    margin: 0 0 12px;
    font-size: clamp(32px, 4.2vw, 56px);
    line-height: 1.1;
    font-weight: 800;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0,0,0,.1);
  }
  .lead {
    max-width: 55ch;
    font-size: clamp(16px, 1.2vw, 18px);
    color: rgba(255,255,255,0.92);
  }
  .cta-group {
    display: block;
    text-align: center;
    margin-top: 32px;
  }
  .hero-cta-unit {
    display: inline-grid;
    grid-template-rows: auto auto;
    justify-items: center;
    text-decoration: none;
    cursor: pointer;
    filter: drop-shadow(0 8px 20px rgba(0,0,0,0.1));
    transition: transform .2s ease-out, filter .2s ease-out;
    will-change: transform, filter;
    outline: none;
  }
  .hero-cta-unit:hover {
    transform: translateY(-4px);
    filter: drop-shadow(0 14px 30px rgba(0,0,0,.15)) brightness(1.03);
  }
  .hero-cta-unit:focus-visible {
    outline: 3px solid #fff;
    outline-offset: 4px;
    border-radius: 16px;
  }
  .btn-hero-top {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px 32px;
    width: 100%;
    font-weight: 850;
    font-size: 18px;
    letter-spacing: .4px;
    text-transform: uppercase;
    background: linear-gradient(180deg, color-mix(in oklab, var(--brand-gold) 86%, white 14%), var(--brand-orange));
    color: var(--ink);
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
  }
  .btn-hero-top::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(110deg, transparent 0%, rgba(255,255,255,.45) 20%, transparent 40%);
    transform: translateX(-120%);
    transition: transform .6s ease;
  }
  .hero-cta-unit:hover .btn-hero-top::after { transform: translateX(120%); }
  @keyframes pulse-border-hero {
    0% { border-color: var(--brand-orange); box-shadow: inset 0 2px 4px rgba(0,0,0,.05), 0 0 0 0 color-mix(in oklab, var(--brand-orange), transparent 55%); }
    50% { border-color: var(--brand-gold); box-shadow: inset 0 2px 4px rgba(0,0,0,.05), 0 0 0 10px color-mix(in oklab, var(--brand-gold), transparent 100%); }
    100% { border-color: var(--brand-orange); box-shadow: inset 0 2px 4px rgba(0,0,0,.05), 0 0 0 0 color-mix(in oklab, var(--brand-orange), transparent 55%); }
  }
  .btn-hero-bonus {
    padding: 10px 20px;
    background-color: var(--surface);
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    width: 90%;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
    border: 2px solid transparent;
    animation: pulse-border-hero 2.2s infinite ease-in-out;
  }
  .art-wrap {
    position: relative;
    perspective: 1200px;
    transform-style: preserve-3d;
    overflow: clip;
  }
  .art-wrap::before {
    content: "";
    position: absolute;
    inset: -10%;
    background: radial-gradient(circle at 50% 50%, color-mix(in oklab, var(--brand-gold) 8%, transparent), transparent 70%);
    filter: blur(32px);
    z-index: 0;
  }
  .hero-art-picture { display: block; }
  .hero__art {
    position: relative;
    z-index: 1;
    display: block;
    height: clamp(340px, 42vw, 500px);
    width: clamp(300px, 44vw, 580px);
    max-width: 100%;
    border-radius: 24px;
    object-fit: cover;
    object-position: top center;
    transform: translateY(30px) translateZ(40px) rotateX(4deg) rotateY(-10deg) scale(1.12);
    transition: transform .6s cubic-bezier(.22,1,.36,1), box-shadow .6s cubic-bezier(.22,1,.36,1);
    will-change: transform;
    backface-visibility: hidden;
  }
  .art-wrap:hover .hero__art {
    transform: translateY(10px) translateZ(60px) rotateX(0) rotateY(0) scale(1.16);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-cta-unit,
    .btn-hero-top::after,
    .btn-hero-bonus,
    .hero__art { transition: none !important; animation: none !important; transform: none !important; }
  }
  @media (max-width: 980px) {
    .hero { padding-bottom: 70px; }
    .hero__inner { grid-template-columns: 1fr; row-gap: 28px; }
    .hero__copy { text-align: center; }
    .art-wrap { margin-top: 0; }
    .hero__art {
      width: 100%;
      max-width: 420px;
      margin-inline: auto;
      transform: translateY(20px) translateZ(20px) rotateX(3deg) scale(1.06);
    }
  }
</style>