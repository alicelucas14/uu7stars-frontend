---
// ===== src/components/MobileAppShell.astro =====
// --- REFACTORED: All links now use the createPath utility for language-awareness ---
import type { Locale } from '../i18n';
import { useTranslations } from '../lib/i18n';
import { createPath } from '../lib/paths'; // <-- IMPORT the new utility

interface Props {
  title?: string;
  active?: 'home' | 'blog' | 'promos' | 'download' | 'faq';
  showBack?: boolean;
  promoBadge?: number;
  showFab?: boolean;
  lang?: Locale;
}
const {
  title = 'Starsuu7',
  active = 'home',
  showBack = false,
  promoBadge = 0,
  showFab = true,
  lang = 'en'
} = Astro.props as Props;

const t = useTranslations(lang);

// --- UPDATED: All hrefs are now built dynamically using createPath ---
const homePath = createPath('/', lang);
const blogPath = createPath('/blog/', lang);
const promosPath = createPath('/#promos', lang);
const downloadPath = createPath('/#download', lang);
const faqPath = createPath('/faq/', lang);
---
<div class="app-shell">
  <!-- Top App Bar -->
  <header class="app-bar" role="banner">
    <div class="app-bar-safe">
      <div class="app-bar-inner container">
        <button
          class="app-icon-btn left"
          aria-label={showBack ? t('mobileAppShell.aria.goBack') : t('mobileAppShell.aria.openMenu')}
          data-action={showBack ? 'back' : 'menu'}
        >
          {showBack ? (
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
          ) : (
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          )}
        </button>

        <a class="app-title" href={homePath} aria-label="Starsuu7 — Home">
          <img src="/logo.webp" alt="" width="24" height="24" class="logo" />
          <span>{title}</span>
        </a>

        <div class="app-actions">
          <a href={downloadPath} class="app-icon-btn" aria-label={t('mobileAppShell.aria.downloadApp')}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 17V3"></path><path d="m6 11 6 6 6-6"></path><path d="M19 21H5"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </header>

  <div class="app-content">
    <slot />
  </div>

  <!-- Bottom Tab Bar -->
  <nav class="tabbar" role="navigation" aria-label="Primary">
    <div class="tabbar-safe">
      <a href={homePath} class={`tab ${active === 'home' ? 'is-active' : ''}`} data-tab="home" aria-label={t('mobileAppShell.home')} aria-current={active==='home'?'page':undefined}>
        <span class="ico"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1v-10.5z"/></svg></span>
        <span class="lbl">{t('mobileAppShell.home')}</span>
      </a>

      <a href={blogPath} class={`tab ${active === 'blog' ? 'is-active' : ''}`} data-tab="blog" aria-label={t('mobileAppShell.blog')} aria-current={active==='blog'?'page':undefined}>
        <span class="ico"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"/><path d="M8 8h8M8 12h8M8 16h5"/></svg></span>
        <span class="lbl">{t('mobileAppShell.blog')}</span>
      </a>

      <a href={promosPath} class={`tab ${active === 'promos' ? 'is-active' : ''}`} data-tab="promos" aria-label={t('mobileAppShell.promos')} aria-current={active==='promos'?'page':undefined}>
        <span class="ico badge-wrap">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 11h18v2H3zM5 7h14M7 3h10M5 21l2-4h10l2 4"/></svg>
          {promoBadge > 0 && <span class="badge" aria-label={`${promoBadge} new promos`}>{promoBadge > 99 ? '99+' : promoBadge}</span>}
        </span>
        <span class="lbl">{t('mobileAppShell.promos')}</span>
      </a>

      <a href={downloadPath} class={`tab ${active === 'download' ? 'is-active' : ''}`} data-tab="download" aria-label={t('mobileAppShell.download')} aria-current={active==='download'?'page':undefined}>
        <span class="ico"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 17V3"/><path d="m6 11 6 6 6-6"/><path d="M19 21H5"/></svg></span>
        <span class="lbl">{t('mobileAppShell.download')}</span>
      </a>

      <a href={faqPath} class={`tab ${active === 'faq' ? 'is-active' : ''}`} data-tab="faq" aria-label={t('mobileAppShell.faq')} aria-current={active==='faq'?'page':undefined}>
        <span class="ico"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9.09 9a3 3 0 1 1 5.82 1c0 2-3 2-3 4"/><path d="M12 17h.01"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0"/></svg></span>
        <span class="lbl">{t('mobileAppShell.faq')}</span>
      </a>
    </div>
  </nav>
</div>

<style>
  /* Styles remain unchanged */
  @media (min-width: 768px) { .app-bar, .tabbar, .dl-fab { display: none; } .app-content { padding-top: 0; padding-bottom: 0; } } .app-shell { position: relative; } .app-bar { position: sticky; top: 0; z-index: 100; background: var(--brand-orange); border-bottom: 1px solid color-mix(in oklab, black 12%, var(--brand-orange)); box-shadow: var(--shadow-md); color: #fff; } .app-bar-safe { padding-top: env(safe-area-inset-top); } .app-bar-inner { display: grid; grid-template-columns: 48px 1fr 48px; align-items: center; height: 60px; } .app-title { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; color: #fff; font-weight: 900; font-size: 17px; letter-spacing: .2px; } .app-title .logo { border-radius: 8px; } .app-icon-btn { display: inline-grid; place-items: center; width: 44px; height: 44px; border-radius: 12px; border: 1px solid color-mix(in oklab, #fff 35%, var(--brand-orange)); background: color-mix(in oklab, var(--brand-orange) 72%, #000 28%); color: #fff; -webkit-tap-highlight-color: transparent; } .app-icon-btn:hover { background: color-mix(in oklab, var(--brand-orange) 60%, #000 40%); } .app-icon-btn:active { transform: translateY(1px); } .app-icon-btn:focus-visible { outline: 3px solid #fff; outline-offset: 2px; } .app-icon-btn svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 2.4; } .app-icon-btn.left { justify-self: start; } .app-actions { display: grid; justify-content: end; } .app-content { padding-top: 0; padding-bottom: calc(72px + env(safe-area-inset-bottom)); } .tabbar  { position: fixed; inset-inline: 0; bottom: 0; z-index: 10020; background: var(--brand-orange); border-top: 1px solid color-mix(in oklab, black 12%, var(--brand-orange)); box-shadow: 0 -6px 18px rgba(0,0,0,.18); color: #fff; } .dl-fab  { z-index: 10030; position: fixed; right: 14px; bottom: calc(86px + env(safe-area-inset-bottom)); display: inline-grid; grid-auto-flow: column; align-items: center; gap: 8px; padding: 12px 14px; border-radius: 16px; text-decoration: none; font-weight: 900; letter-spacing: .2px; background: linear-gradient(180deg, var(--brand-gold), var(--brand-orange)); color: #0b0b0f; box-shadow: 0 10px 30px rgba(0,0,0,.25); border: 1px solid color-mix(in oklab, #000 12%, var(--brand-gold)); -webkit-tap-highlight-color: transparent; } .dl-fab svg { width: 22px; height: 22px; stroke: currentColor; fill: none; stroke-width: 2.6; } .dl-fab:active { transform: translateY(1px); } .dl-fab:focus-visible { outline: 3px solid #fff; outline-offset: 2px; } .tabbar-safe { display: grid; grid-template-columns: repeat(5, 1fr); align-items: stretch; height: calc(64px + env(safe-area-inset-bottom)); padding-bottom: env(safe-area-inset-bottom); } .tab { display: grid; place-items: center; gap: 6px; text-decoration: none; color: color-mix(in oklab, #fff 88%, #000); font-size: 12px; padding-block: 8px; -webkit-tap-highlight-color: transparent; position: relative; } .tab .ico svg { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 2.6; } .tab .lbl { font-weight: 700; letter-spacing: .1px; } .tab.is-active { color: #fff; } .tab.is-active .lbl { color: var(--brand-gold); } .tab:active { background: color-mix(in oklab, var(--brand-orange) 70%, #000 30%); } .tab:focus-visible { outline: 3px solid #fff; outline-offset: -3px; border-radius: 12px; } .badge-wrap { position: relative; } .badge { position: absolute; top: -4px; right: -10px; min-width: 18px; height: 18px; padding: 0 5px; border-radius: 10px; background: var(--brand-gold); color: #0b0b0f; font-size: 10px; font-weight: 900; line-height: 18px; text-align: center; border: 1px solid color-mix(in oklab, #000 20%, var(--brand-gold)); } @media (prefers-reduced-motion: reduce) { .app-icon-btn:active, .tab:active, .dl-fab:active { transform: none; } } @media (max-width: 767px) { :global(.site-header) { display: none !important; } }
</style>

<script is:inline>
  // Script remains unchanged
  document.addEventListener('click', (e) => { const el = e.target; if (!(el instanceof Element)) return; const btn = el.closest('[data-action]'); if (!btn) return; const action = btn.getAttribute('data-action'); if (action === 'back') { e.preventDefault(); if (history.length > 1) history.back(); } if (action === 'menu') { e.preventDefault(); if (window.AppMenu && typeof window.AppMenu.open === 'function') { window.AppMenu.open(); } else { window.dispatchEvent(new CustomEvent('open-global-menu')); } } }, { passive: false }); function haptic(){ try{ navigator.vibrate && navigator.vibrate(12); } catch{} } document.querySelectorAll('.tabbar a').forEach(a => a.addEventListener('click', () => haptic(), { passive: true })); function isSamePageHashLink(a){ if (!a.hash) return false; const currentPath = window.location.pathname.replace(/\/hi\//, '/'); return a.pathname === currentPath || a.pathname.replace(/\/$/, '') === currentPath.replace(/\/$/, ''); } function offsetTopFor(id){ const el = document.querySelector(id); if(!el) return 0; const bar = document.querySelector('.app-bar'); const h = bar ? bar.getBoundingClientRect().height : 60; const y = el.getBoundingClientRect().top + window.scrollY; return Math.max(0, y - h - 8); } function smoothTo(hash){ const y = offsetTopFor(hash); window.scrollTo({ top: y, behavior: 'smooth' }); } document.querySelectorAll('.tabbar a').forEach((a) => { a.addEventListener('click', (e) => { if (!isSamePageHashLink(a)) return; e.preventDefault(); haptic(); smoothTo(a.hash); history.pushState(null,'',a.hash); }, { passive: false }); }); const fab = document.querySelector('[data-fab]'); if (fab && 'IntersectionObserver' in window) { const targets = ['.site-footer'].map(s => document.querySelector(s)).filter(Boolean); if (targets.length) { const obs = new IntersectionObserver((entries) => { const visible = entries.some(e => e.isIntersecting); fab.style.opacity = visible ? '0' : '1'; fab.style.pointerEvents = visible ? 'none' : 'auto'; fab.style.transform = visible ? 'translateY(8px)' : 'translateY(0)'; }, { rootMargin: '0px 0px -20% 0px', threshold: 0.01 }); targets.forEach(t => obs.observe(t)); } }
</script>