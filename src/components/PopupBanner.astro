---
// ===== src/components/PopupBanner.astro =====
import { getSettings } from '../services/api';

const settings = await getSettings();

const API_BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;
const rawImage = settings?.popupBannerImageUrl || '';
const imageUrl = rawImage ? (rawImage.startsWith('http') ? rawImage : `${API_BASE_URL}${rawImage}`) : '';
const showBanner = settings?.showPopupBanner && imageUrl;
const bannerLink = settings?.popupBannerLink || '';
---

{showBanner && (
  <div id="popup-banner-modal" class="popup-modal" aria-hidden="true" style="display: none;">
    <div class="popup-backdrop"></div>
    <div class="popup-container">
      <div class="popup-content">
        <button id="popup-close-btn" class="popup-close-btn" aria-label="Close promotion modal">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        {bannerLink ? (
          <a href={bannerLink} target="_blank" rel="noopener noreferrer" class="popup-banner-link">
            <img src={imageUrl} alt="Promotion Banner" class="popup-banner-img" />
          </a>
        ) : (
          <img src={imageUrl} alt="Promotion Banner" class="popup-banner-img" />
        )}
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      const modal = document.getElementById('popup-banner-modal');
      if (!modal) return;

      // Check if already dismissed in this session
      if (!sessionStorage.getItem('popupBannerDismissed')) {
        // Display the modal with a slight delay for better experience
        setTimeout(() => {
          modal.style.display = 'flex';
          // Force a layout reflow for CSS transition
          modal.offsetHeight;
          modal.classList.add('is-active');
          modal.setAttribute('aria-hidden', 'false');
        }, 800);
      }

      function closeModal() {
        modal.classList.remove('is-active');
        modal.setAttribute('aria-hidden', 'true');
        sessionStorage.setItem('popupBannerDismissed', 'true');
        // Wait for animation to finish before hiding display
        setTimeout(() => {
          modal.style.display = 'none';
        }, 300);
      }

      const closeBtn = document.getElementById('popup-close-btn');
      const backdrop = modal.querySelector('.popup-backdrop');

      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', closeModal);
    })();
  </script>

  <style>
    .popup-modal {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    
    .popup-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(8px);
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    
    .popup-container {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 500px;
      transform: scale(0.9) translateY(20px);
      opacity: 0;
      transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
    }
    
    .popup-modal.is-active .popup-backdrop {
      opacity: 1;
    }
    
    .popup-modal.is-active .popup-container {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
    
    .popup-content {
      position: relative;
      background: #15151a; /* deep premium dark surface */
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
    }
    
    .popup-close-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      z-index: 20;
      background: rgba(0, 0, 0, 0.7);
      color: #ffffff;
      border: 1px solid rgba(255, 255, 255, 0.15);
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      cursor: pointer;
      transition: background-color 0.2s, transform 0.2s;
    }
    
    .popup-close-btn:hover {
      background: rgba(239, 68, 68, 0.95); /* modern red alert color */
      transform: scale(1.05);
    }
    
    .popup-banner-link {
      display: block;
      cursor: pointer;
    }
    
    .popup-banner-img {
      width: 100%;
      height: auto;
      display: block;
      max-height: 70vh;
      object-fit: contain;
    }
  </style>
)}
