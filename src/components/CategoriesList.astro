---
// ===== src/components/CategoriesList.astro =====
// --- CORRECTED: Uses centralized slugify for links ---
import { getBlogPosts } from '../services/api';
import type { Locale } from '../i18n';
import { createPath, slugify } from '../lib/paths'; // <-- IMPORT slugify

interface Props {
  lang?: Locale;
}
const { lang = 'en' } = Astro.props;

const allPosts = await getBlogPosts(lang);
const categories = [...new Set(allPosts.map(post => post.tags[0]).filter(Boolean))];
---

{categories.length > 0 && (
  <div class="sidebar-widget">
    <h3 class="widget-title">Categories</h3>
    <ul class="category-list">
      {categories.map(category => (
        <li>
          {/* CORRECTED LINK */}
          <a href={createPath(`/blog/category/${slugify(category)}/`, lang)}>
            {category}
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
<style>
/* Styles remain unchanged */
.sidebar-widget{background:var(--surface);border:1px solid var(--ring);border-radius:16px;padding:20px}.widget-title{margin:0 0 16px;font-size:18px;border-bottom:1px solid var(--ring);padding-bottom:12px}.category-list{list-style:none;padding:0;margin:0;display:grid;gap:12px}.category-list a{display:block;padding:8px 12px;border-radius:8px;text-decoration:none;font-weight:600;color:var(--text-secondary);background-color:var(--surface-2);border:1px solid var(--ring);transition:all .2s ease-out}.category-list a:hover{color:var(--brand-orange);background-color:var(--surface);border-color:var(--brand-orange)}
</style>