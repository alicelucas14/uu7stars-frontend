# ===================================================================
#   CORRECT .HTACCESS FOR ASTRO SSR ON CPANEL (NODE.JS + PASSENGER)
# ===================================================================
# -------------------------------------------------------------------
#   URL REWRITING RULES
# -------------------------------------------------------------------
# Enable the rewrite engine
RewriteEngine On
# 1. Force HTTPS and non-www
# This redirects http://, http://www., and https://www. to https://
RewriteCond %{HTTP_HOST} ^www\. [NC,OR]
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,NE,R=301]
# 2. Front-Controller Rule for SSR
# This is the most important part.
# If the requested path is NOT an existing file on the server...
RewriteCond %{REQUEST_FILENAME} !-f
# And if it's NOT an existing directory...
RewriteCond %{REQUEST_FILENAME} !-d
# Then let Passenger/Node.js handle the request.
# The '-' means "don't rewrite the URL", just pass it through.
# The [L] flag means "stop processing any more rules".
RewriteRule ^(.*)$ - [L]
